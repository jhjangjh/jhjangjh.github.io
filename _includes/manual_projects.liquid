{% if site.data.projects and site.data.projects.size > 0 %}
  <h2>Projects</h2>

  <div class="manual-projects">
    <ul class="project-list">
      {% for project in site.data.projects %}
        <li class="project-item">
          <span class="project-marker" aria-hidden="true"></span>

          {% if project.image and project.image != "" %}
            <div class="project-image">
              <img src="{{ project.image | relative_url }}" alt="{{ project.title }}">
            </div>
          {% endif %}

          <div class="project-content">
            <span class="project-title">{{ project.title }}</span>

            {% if project.people and project.people.size > 0 %}
              <div class="project-people">
                with
                {% for person in project.people %}
                  {% if person.url and person.url != "" %}
                    <a class="project-person-link" href="{{ person.url }}" target="_blank" rel="noopener noreferrer">{{ person.name }}</a>
                  {% else %}
                    <span>{{ person.name }}</span>
                  {% endif %}{% unless forloop.last %}, {% endunless %}
                {% endfor %}
              </div>
            {% endif %}

            {% if project.period and project.period != "" %}
              <div class="project-period">{{ project.period }}</div>
            {% endif %}

            {% assign has_project_links = false %}
            {% if project.page_url and project.page_url != "" %}
              {% assign has_project_links = true %}
            {% endif %}
            {% if project.demo_url and project.demo_url != "" %}
              {% assign has_project_links = true %}
            {% endif %}
            {% if project.github_url and project.github_url != "" %}
              {% assign has_project_links = true %}
            {% endif %}

            {% if has_project_links %}
              <div class="project-links">
                {% if project.page_url and project.page_url != "" %}
                  <a href="{{ project.page_url }}">[page]</a>
                {% endif %}
                {% if project.demo_url and project.demo_url != "" %}
                  <a href="{{ project.demo_url }}">[demo]</a>
                {% endif %}
                {% if project.github_url and project.github_url != "" %}
                  <a href="{{ project.github_url }}">[github]</a>
                {% endif %}
              </div>
            {% endif %}
          </div>
        </li>
      {% endfor %}
    </ul>
  </div>
{% endif %}

<style>
  .manual-projects {
    margin-top: 0.75rem;
  }

  .project-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .project-item {
    color: #111827;
    display: flex;
    gap: 1rem;
    line-height: 1.45;
    margin-bottom: 1.5rem;
    padding-left: 1.55rem;
    position: relative;
  }

  .project-marker {
    background: #7c8795;
    height: 0.3rem;
    left: 0.45rem;
    position: absolute;
    top: 0.62rem;
    width: 0.3rem;
  }

  .project-image {
    aspect-ratio: 4 / 3;
    background: var(--global-card-bg-color);
    border: 1px solid var(--global-divider-color);
    border-radius: 6px;
    flex: 0 0 9rem;
    overflow: hidden;
  }

  .project-image img {
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .project-content {
    min-width: 0;
  }

  .project-title {
    font-weight: 700;
  }

  .project-people,
  .project-period {
    color: #667789;
  }

  .project-person-link {
    border-bottom: 1px solid #8fcfc2;
    color: inherit;
  }

  .project-links a {
    font-weight: 700;
    margin-right: 0.35rem;
  }

  @media (max-width: 640px) {
    .project-item {
      display: block;
    }

    .project-image {
      margin-bottom: 0.6rem;
      max-width: 12rem;
    }
  }
</style>
