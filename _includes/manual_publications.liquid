{% unless include.hide_title %}
  <h2>Publications</h2>
{% endunless %}

<div class="manual-publications">
  <p class="publication-notes">
    <span class="selected-star">&#9733;</span> <em>denotes selected publications</em><br>
    <em>[C]: Conference Paper [J]: Journal Paper [P]: Preprint</em>
  </p>

  <ul class="publication-list">
    {% for paper in site.data.publications %}
      <li class="publication-item">
        <span class="publication-marker" aria-hidden="true"></span>

        {% if paper.image and paper.image != "" %}
          <div class="publication-image">
            <img src="{{ paper.image | relative_url }}" alt="{{ paper.title }}">
          </div>
        {% endif %}

        <div class="publication-content">
          {% if paper.selected %}
            <span class="selected-star" aria-label="selected publication">&#9733;</span>
          {% endif %}
          <span class="publication-title">[{{ paper.tag }}] {{ paper.title }}</span>

          <div class="publication-authors">
            {% for author in paper.authors %}
              {% if author.me %}
                <span class="publication-author me-author">
                  {{ author.name }}{% if author.equal %}*{% endif %}
                </span>
              {% elsif author.url and author.url != "" %}
                <a class="publication-author publication-author-link" href="{{ author.url }}" target="_blank" rel="noopener noreferrer">
                  {{ author.name }}{% if author.equal %}*{% endif %}
                </a>
              {% else %}
                <span class="publication-author">
                  {{ author.name }}{% if author.equal %}*{% endif %}
                </span>
              {% endif %}{% unless forloop.last %}, {% endunless %}
            {% endfor %}
          </div>

          <div class="publication-venue">
            {{ paper.venue }}
            {% if paper.note and paper.note != "" %}
              <span class="publication-note">({{ paper.note }})</span>
            {% endif %}
          </div>

          {% assign has_publication_links = false %}
          {% if paper.page_url and paper.page_url != "" %}
            {% assign has_publication_links = true %}
          {% endif %}
          {% if paper.paper_url and paper.paper_url != "" %}
            {% assign has_publication_links = true %}
          {% endif %}
          {% if paper.github_url and paper.github_url != "" %}
            {% assign has_publication_links = true %}
          {% endif %}
          {% if paper.links and paper.links.size > 0 %}
            {% assign has_publication_links = true %}
          {% endif %}

          {% if has_publication_links %}
            <div class="publication-links">
              {% if paper.page_url and paper.page_url != "" %}
                <a href="{{ paper.page_url }}">Page</a>
              {% endif %}
              {% if paper.paper_url and paper.paper_url != "" %}
                <a href="{{ paper.paper_url }}">Paper</a>
              {% endif %}
              {% if paper.github_url and paper.github_url != "" %}
                <a href="{{ paper.github_url }}">Code</a>
              {% endif %}
              {% for link in paper.links %}
                <a href="{{ link.url }}">{{ link.label }}</a>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      </li>
    {% endfor %}
  </ul>
</div>

<style>
  .manual-publications {
    margin-top: 0.75rem;
  }

  .publication-notes {
    color: #5f6f82;
    line-height: 1.55;
    margin-bottom: 1.35rem;
  }

  .publication-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .publication-item {
    display: flex;
    gap: 1rem;
    line-height: 1.45;
    margin-bottom: 1.8rem;
    padding-left: 1.55rem;
    position: relative;
  }

  .publication-marker {
    background: #3f7fca;
    border-radius: 999px;
    height: 1.15rem;
    left: 0.2rem;
    position: absolute;
    top: 0.24rem;
    width: 0.28rem;
  }

  .publication-image {
    aspect-ratio: 4 / 3;
    background: var(--global-card-bg-color);
    border: 1px solid var(--global-divider-color);
    border-radius: 6px;
    flex: 0 0 9rem;
    overflow: hidden;
  }

  .publication-image img {
    height: 100%;
    object-fit: contain;
    width: 100%;
  }

  .publication-content {
    min-width: 0;
  }

  .selected-star {
    color: #f5a400;
    font-weight: 700;
  }

  .publication-authors,
  .publication-venue {
    color: #667789;
  }

  .publication-author {
    color: inherit;
  }

  .publication-author-link {
    color: inherit;
    text-decoration: none;
  }

  .me-author {
    color: #3f7fca;
    font-weight: 700;
  }

  .publication-title {
    font-weight: 700;
  }

  .publication-note {
    color: #d64545;
    font-weight: 700;
  }

  .publication-links a {
    color: #8fcfc2;
    font-weight: 700;
    margin-right: 0.35rem;
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .publication-item {
      display: block;
    }

    .publication-image {
      margin-bottom: 0.6rem;
      max-width: 12rem;
    }
  }
</style>
