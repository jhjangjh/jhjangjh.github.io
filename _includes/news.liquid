{% assign news = site.news | reverse %}

{% if news.size > 0 %}
<section id="news" class="profile-section news-section">
<h2>News</h2>
<div class="news">
  <div class="table-responsive">
    <table class="table table-sm table-borderless">
      {% for item in news %}
        <tr>
          <th scope="row" style="width: 20%">
            {{ item.date | date: "%b %Y" }}
          </th>
          <td>
            {% if item.inline %}
              {{ item.content | remove: '<p>' | remove: '</p>' }}
            {% else %}
              <a class="news-title" href="{{ item.url | relative_url }}">{{ item.title }}</a>
            {% endif %}
          </td>
        </tr>
      {% endfor %}
    </table>
  </div>
</div>
</section>
<script>
  document.addEventListener("DOMContentLoaded", function () {
    var newsSection = document.querySelector(".news-section");
    var previousHeading = newsSection ? newsSection.previousElementSibling : null;

    if (previousHeading && previousHeading.tagName === "H2" && previousHeading.textContent.trim().toLowerCase() === "news") {
      previousHeading.hidden = true;
    }
  });
</script>
{% endif %}

{% if page.permalink == "/" %}
  {% include home_sections.liquid %}
{% endif %}
